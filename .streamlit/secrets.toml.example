# 叙事增强 D 组共振 v2.0 配置模板
# ==================================
# 把本文件复制为 `.streamlit/secrets.toml`（已被 .gitignore 忽略），按需填入实际值。
# Streamlit Cloud 部署时通过 web 控制台 Secrets 面板配置同名键。

FRED_API_KEY = "REPLACE_WITH_FRED_KEY"

# Feature flag：v2_on / v2_off / v1_legacy
# - v2_on    : 启用三桥共振榜（默认推荐）
# - v2_off   : 隐藏共振区块，只显示 ScorecardD 主榜
# - v1_legacy: 仅用于对照旧口径回看，禁止再做新功能
ENABLE_NARRATIVE_RESONANCE_V2 = "v2_on"

# 后端 internal token（与 Render 环境变量 RESONANCE_INTERNAL_TOKEN 必须一致）
# 64 位随机串生成：python -c "import secrets; print(secrets.token_hex(32))"
RESONANCE_INTERNAL_TOKEN = "PLEASE_REPLACE_WITH_64_HEX_CHARS"

# === Render 后端同步配置说明 ===
# 在 Render 服务 Settings → Environment 添加：
#   RESONANCE_INTERNAL_TOKEN = <同上 64 位随机串>
# token 不一致会导致 401 invalid internal token；空值 503 not configured。
